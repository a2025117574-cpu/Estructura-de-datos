def factorial (numero):
    
    if(numero == 0 or numero ==1):
        return 1
    else:
        return numero*factorial(numero -1)
    
def cuenta_atras(numero):
    
    if (numero==0):
        print(0)
        return 0
    else:
        print(numero)
        return cuenta_atras(numero-1)
    
def potencia(base,exponente):
    
    if(exponente==0):
        return 1
    else:
        return base*potencia(base,exponente-1)
    
